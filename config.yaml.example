# Joe Goldberg — configuration
# Copy this file to config.yaml and fill in your values
# NEVER commit config.yaml — it contains secrets

model: llama3.2:3b
ollama_url: http://localhost:11434

# ── Gemini API (recommended — free tier, fast) ─────────────────
# Get your free key at: https://aistudio.google.com/apikey
# Then set it as an environment variable (recommended):
#   export GEMINI_API_KEY="your_key_here"
#   echo 'export GEMINI_API_KEY="your_key_here"' >> ~/.bashrc
#
# Or paste it here (less secure — make sure config.yaml is gitignored):
gemini_api_key: YOUR_GEMINI_API_KEY_HERE

assets_dir: assets
cases_dir: cases
joe_image: joe.jpeg

tools:
  sherlock: true
  maigret: true
  whois: true
  dns: true
  crt_sh: true
  nmap: false

ui:
  mode: desktop
  theme: warm_cream